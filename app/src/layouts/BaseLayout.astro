---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Choisissez le bon framework frontend pour votre projet.' } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — Framework Selector</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen" style="background-color: var(--text-brume); color: var(--primary-abime);">
    <header class="border-b sticky top-0 z-50 backdrop-blur" style="background-color: var(--primary-abime); border-color: #0f1e23;">
      <nav class="max-w-7xl mx-auto px-4 h-14 flex items-center gap-6">
        <a href="/" class="font-bold text-lg tracking-tight" style="color: var(--text-brume);">⚡ Framework Selector</a>
        <div class="flex-1" />
        <a href="/wizard" class="text-sm font-medium transition-colors hover:opacity-80" style="color: var(--accent-balise);">Wizard</a>
        <a href="/compare" class="text-sm transition-colors hover:opacity-80" style="color: var(--neutral-calcaire);">Comparer</a>
        <a href="/demos" class="text-sm transition-colors hover:opacity-80" style="color: var(--neutral-calcaire);">Demos</a>
        <div class="h-4 w-px opacity-30" style="background-color: var(--neutral-calcaire);" />
        <a href="/frameworks/react" class="text-sm transition-colors opacity-60 hover:opacity-100" style="color: var(--text-brume);">React</a>
        <a href="/frameworks/angular" class="text-sm transition-colors opacity-60 hover:opacity-100" style="color: var(--text-brume);">Angular</a>
        <a href="/frameworks/vue" class="text-sm transition-colors opacity-60 hover:opacity-100" style="color: var(--text-brume);">Vue</a>
        <a href="/frameworks/svelte" class="text-sm transition-colors opacity-60 hover:opacity-100" style="color: var(--text-brume);">Svelte</a>
        <a href="/frameworks/astro" class="text-sm transition-colors opacity-60 hover:opacity-100" style="color: var(--text-brume);">Astro</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="border-t mt-24 py-8 text-center text-sm" style="border-color: var(--neutral-calcaire); color: #64748b;">
      Source : notebook NotebookLM <em>front-end-studies-2025-2026</em>
    </footer>
  </body>
</html>
