---
import BaseLayout from '../layouts/BaseLayout.astro';
import { frameworks } from '../data/frameworks';
---

<BaseLayout title="Accueil">
  <!-- Hero -->
  <section class="max-w-4xl mx-auto px-4 pt-20 pb-16 text-center">
    <p class="text-indigo-400 text-sm font-semibold uppercase tracking-widest mb-4">Ecosysteme Web 2025–2026</p>
    <h1 class="text-4xl sm:text-5xl font-bold text-white mb-6 leading-tight">
      Quel framework frontend<br />choisir pour votre projet ?
    </h1>
    <p class="text-gray-400 text-lg mb-10 max-w-2xl mx-auto">
      Synthese basee sur les donnees 2025–2026 : benchmarks, cas d'utilisation,
      courbes d'apprentissage et recommandations AI-first.
    </p>
    <div class="flex flex-wrap gap-4 justify-center">
      <a href="/wizard"
        class="bg-indigo-600 hover:bg-indigo-500 text-white font-semibold px-6 py-3 rounded-lg transition-colors">
        Demarrer le wizard →
      </a>
      <a href="/compare"
        class="border border-gray-700 hover:border-gray-500 text-gray-300 hover:text-white font-semibold px-6 py-3 rounded-lg transition-colors">
        Voir la matrice
      </a>
    </div>
  </section>

  <!-- Cards frameworks -->
  <section class="max-w-7xl mx-auto px-4 pb-20">
    <h2 class="text-xl font-semibold text-gray-300 mb-8 text-center">Les 5 frameworks couverts</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
      {frameworks.map((f) => (
        <a href={`/frameworks/${f.id}`}
          class="group bg-gray-900 border border-gray-800 hover:border-gray-600 rounded-xl p-5 transition-all hover:-translate-y-1">
          <div class="text-3xl mb-3">{f.icon}</div>
          <div class="font-bold text-white text-lg">{f.name} <span class="text-xs text-gray-500">{f.version}</span></div>
          <div class="text-xs text-gray-400 mt-1 mb-4">{f.tagline}</div>
          <div class="flex flex-wrap gap-1">
            {f.renderPatterns.slice(0, 3).map(p => (
              <span class="text-xs bg-gray-800 text-gray-400 px-2 py-0.5 rounded">{p}</span>
            ))}
          </div>
          <div class="mt-4 grid grid-cols-2 gap-2 text-xs">
            <div class="bg-gray-800 rounded p-2">
              <div class="text-gray-500">Bundle</div>
              <div class="text-white font-mono">{f.benchmarks.bundleStarter}</div>
            </div>
            <div class="bg-gray-800 rounded p-2">
              <div class="text-gray-500">TTI</div>
              <div class="text-white font-mono">{f.benchmarks.tti}</div>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Decision rapide -->
  <section class="max-w-4xl mx-auto px-4 pb-20">
    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-8">
      <h2 class="text-xl font-bold text-white mb-6">Recommandation rapide</h2>
      <div class="grid gap-3">
        {[
          { need: 'SEO & performance maximale', rec: 'Astro', id: 'astro', why: 'Zero JS par defaut, Islands Architecture' },
          { need: 'Dashboard / SaaS + features AI', rec: 'React / Next.js', id: 'react', why: 'Vercel AI SDK, ecosysteme imbattable' },
          { need: 'Performance raw + petite equipe', rec: 'SvelteKit', id: 'svelte', why: '200ms TTI, 1200 RPS, bundles <10 KB' },
          { need: 'Application enterprise massive', rec: 'Angular', id: 'angular', why: 'Structure, DI, maintenabilite long terme' },
          { need: 'Prototype rapide / equipe junior', rec: 'Vue', id: 'vue', why: "Courbe d'apprentissage minimale" },
        ].map(row => (
          <div class="flex items-center gap-4 p-3 bg-gray-800 rounded-lg">
            <div class="text-sm text-gray-400 flex-1">Si votre besoin est <span class="text-white font-medium">{row.need}</span></div>
            <div class="text-sm font-bold text-indigo-400 shrink-0">→</div>
            <a href={`/frameworks/${row.id}`} class="text-sm font-bold text-white hover:text-indigo-300 transition-colors shrink-0">{row.rec}</a>
            <div class="text-xs text-gray-500 hidden lg:block">{row.why}</div>
          </div>
        ))}
      </div>
      <div class="mt-6 text-center">
        <a href="/wizard" class="text-indigo-400 hover:text-indigo-300 text-sm transition-colors">
          Besoin d'une recommandation personnalisee ? → Utiliser le wizard
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
