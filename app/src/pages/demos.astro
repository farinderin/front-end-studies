---
import BaseLayout from '../layouts/BaseLayout.astro';
import CounterReact from '../components/demos/CounterReact';
import CounterVue from '../components/demos/CounterVue.vue';
import CounterSvelte from '../components/demos/CounterSvelte.svelte';

const demoCode = {
  react: `import { useState } from 'react';

export default function Counter() {
  const [count, setCount] = useState(0);
  return (
    <div>
      <div>{count}</div>
      <button onClick={() => setCount(c => c - 1)}>−</button>
      <button onClick={() => setCount(0)}>reset</button>
      <button onClick={() => setCount(c => c + 1)}>+</button>
    </div>
  );
}`,
  vue: `<script setup lang="ts">
import { ref } from 'vue';
const count = ref(0);
</script>

<template>
  <div>
    <div>{{ count }}</div>
    <button @click="count--">−</button>
    <button @click="count = 0">reset</button>
    <button @click="count++">+</button>
  </div>
</template>`,
  svelte: `<script lang="ts">
  let count = $state(0);
</script>

<div>
  <div>{count}</div>
  <button onclick={() => count--}>−</button>
  <button onclick={() => count = 0}>reset</button>
  <button onclick={() => count++}>+</button>
</div>`,
};
---

<BaseLayout title="Demos Islands" description="Le meme composant implemente en React, Vue et Svelte sur la meme page Astro.">
  <div class="max-w-5xl mx-auto px-4 py-16">
    <div class="text-center mb-12">
      <h1 class="text-3xl font-bold mb-3" style="color: var(--primary-abime);">Islands Architecture en action</h1>
      <p class="max-w-2xl mx-auto" style="color: #475569;">
        Le meme composant — un compteur interactif — implemente en React, Vue et Svelte,
        tous hydrates independamment sur cette page Astro statique.
      </p>
      <div class="mt-4 inline-flex items-center gap-2 bg-white border rounded-full px-4 py-1.5 text-xs" style="border-color: var(--neutral-calcaire); color: #475569;">
        <span class="w-2 h-2 rounded-full" style="background-color: var(--secondary-foret);"></span>
        3 islands actives — le reste de la page : 0 KB de JS
      </div>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      <!-- React Island -->
      <div class="bg-white border rounded-2xl overflow-hidden" style="border-color: var(--neutral-calcaire);">
        <div class="p-4 border-b flex items-center gap-3" style="border-color: var(--neutral-calcaire); background-color: var(--primary-abime);">
          <span class="text-xl">⚛️</span>
          <div>
            <div class="font-semibold text-sm" style="color: var(--text-brume);">React 19</div>
            <div class="text-xs" style="color: #94a3b8;">useState + JSX</div>
          </div>
          <div class="ml-auto flex gap-1">
            <span class="text-xs px-2 py-0.5 rounded" style="background-color: #1e3a5f; color: #93c5fd; border: 1px solid #1e40af;">32–40 KB</span>
            <span class="text-xs px-2 py-0.5 rounded" style="background-color: #0f2027; color: #94a3b8;">350ms TTI</span>
          </div>
        </div>
        <CounterReact client:load />
        <div class="p-4 border-t" style="border-color: var(--neutral-calcaire);">
          <pre class="code-snippet text-xs overflow-x-auto leading-relaxed rounded p-3"><code>{demoCode.react}</code></pre>
        </div>
      </div>

      <!-- Vue Island -->
      <div class="bg-white border rounded-2xl overflow-hidden" style="border-color: var(--neutral-calcaire);">
        <div class="p-4 border-b flex items-center gap-3" style="border-color: var(--neutral-calcaire); background-color: var(--primary-abime);">
          <span class="text-xl">💚</span>
          <div>
            <div class="font-semibold text-sm" style="color: var(--text-brume);">Vue 3.6</div>
            <div class="text-xs" style="color: #94a3b8;">ref() + template</div>
          </div>
          <div class="ml-auto flex gap-1">
            <span class="text-xs px-2 py-0.5 rounded" style="background-color: #14532d; color: #86efac; border: 1px solid #166534;">18–22 KB</span>
            <span class="text-xs px-2 py-0.5 rounded" style="background-color: #0f2027; color: #94a3b8;">300ms TTI</span>
          </div>
        </div>
        <CounterVue client:load />
        <div class="p-4 border-t" style="border-color: var(--neutral-calcaire);">
          <pre class="code-snippet text-xs overflow-x-auto leading-relaxed rounded p-3"><code>{demoCode.vue}</code></pre>
        </div>
      </div>

      <!-- Svelte Island -->
      <div class="bg-white border rounded-2xl overflow-hidden" style="border-color: var(--neutral-calcaire);">
        <div class="p-4 border-b flex items-center gap-3" style="border-color: var(--neutral-calcaire); background-color: var(--primary-abime);">
          <span class="text-xl">🔥</span>
          <div>
            <div class="font-semibold text-sm" style="color: var(--text-brume);">Svelte 5</div>
            <div class="text-xs" style="color: #94a3b8;">$state (Runes)</div>
          </div>
          <div class="ml-auto flex gap-1">
            <span class="text-xs px-2 py-0.5 rounded" style="background-color: #7c2d12; color: #fdba74; border: 1px solid #9a3412;">&lt;10 KB</span>
            <span class="text-xs px-2 py-0.5 rounded" style="background-color: #0f2027; color: #94a3b8;">200ms TTI</span>
          </div>
        </div>
        <CounterSvelte client:load />
        <div class="p-4 border-t" style="border-color: var(--neutral-calcaire);">
          <pre class="code-snippet text-xs overflow-x-auto leading-relaxed rounded p-3"><code>{demoCode.svelte}</code></pre>
        </div>
      </div>
    </div>

    <!-- Note Islands -->
    <div class="mt-10 bg-white border border-dashed rounded-xl p-6 text-sm" style="border-color: var(--neutral-calcaire);">
      <p class="font-semibold mb-2" style="color: var(--primary-abime);">Pourquoi Astro pour cette demo ?</p>
      <p style="color: #475569;">
        Astro est le seul framework qui peut embarquer des composants React, Vue et Svelte
        <strong style="color: var(--primary-abime);"> sur la meme page</strong> via son systeme d'Islands.
        Chaque island est hydratee independamment (<code class="font-mono text-xs px-1 py-0.5 rounded" style="background-color: var(--neutral-calcaire); color: var(--accent-balise);">client:load</code>).
        Le reste du contenu est du HTML statique — zero overhead, meilleur LCP.
      </p>
    </div>
  </div>
</BaseLayout>
