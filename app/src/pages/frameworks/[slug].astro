---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { frameworks, type Framework } from '../../data/frameworks';

export function getStaticPaths() {
  return frameworks.map(f => ({ params: { slug: f.id }, props: { framework: f } }));
}

interface Props { framework: Framework; }
const { framework: f } = Astro.props;

const learningLabel = { facile: '🟢 Facile', moderee: '🟡 Moderee', difficile: '🔴 Difficile' };
const ecosystemLabel = { 'tres-grand': '★★★★ Tres grand', grand: '★★★ Grand', moyen: '★★ Moyen', petit: '★ Petit' };
---

<BaseLayout title={`${f.name} ${f.version}`} description={f.tagline}>
  <div class="max-w-4xl mx-auto px-4 py-16">
    <!-- Header -->
    <div class="mb-10">
      <div class="flex items-center gap-4 mb-4">
        <span class="text-5xl">{f.icon}</span>
        <div>
          <h1 class="text-3xl font-bold" style={`color: ${f.color}`}>
            {f.name} <span class="text-gray-500 text-xl font-normal">{f.version}</span>
          </h1>
          <p class="text-gray-400 mt-1">{f.tagline}</p>
        </div>
      </div>
      <div class="flex flex-wrap gap-2">
        {f.renderPatterns.map(p => (
          <span class="text-xs border px-2 py-1 rounded font-mono" style="background-color: var(--neutral-calcaire); border-color: #cbd5e1; color: var(--primary-abime);">{p}</span>
        ))}
      </div>
    </div>

    <!-- Benchmarks -->
    <section class="mb-10">
      <h2 class="text-lg font-semibold mb-4" style="color: var(--secondary-foret);">Benchmarks</h2>
      <div class="grid grid-cols-2 sm:grid-cols-5 gap-3">
        {[
          { label: 'Bundle starter', value: f.benchmarks.bundleStarter },
          { label: 'TTI', value: f.benchmarks.tti },
          { label: 'RPS serveur', value: f.benchmarks.rps },
          { label: 'Adoption', value: f.benchmarks.adoption },
          { label: 'Satisfaction', value: f.benchmarks.satisfaction },
        ].map(b => (
          <div class="bg-white border rounded-lg p-3" style="border-color: var(--neutral-calcaire);">
            <div class="text-xs mb-1" style="color: #64748b;">{b.label}</div>
            <div class="font-mono font-bold" style="color: var(--primary-abime);">{b.value || '—'}</div>
          </div>
        ))}
      </div>
    </section>

    <div class="grid md:grid-cols-2 gap-8 mb-10">
      <!-- Ideal pour -->
      <section>
        <h2 class="text-lg font-semibold mb-4" style="color: var(--secondary-foret);">✅ Ideal pour</h2>
        <ul class="space-y-2">
          {f.idealFor.map(item => (
            <li class="flex gap-2 text-sm" style="color: var(--primary-abime);">
              <span class="shrink-0" style="color: var(--secondary-foret);">•</span>
              {item}
            </li>
          ))}
        </ul>
      </section>

      <!-- A eviter -->
      <section>
        <h2 class="text-lg font-semibold mb-4" style="color: var(--secondary-foret);">⚠️ A eviter si</h2>
        <ul class="space-y-2">
          {f.notIdealFor.map(item => (
            <li class="flex gap-2 text-sm" style="color: var(--primary-abime);">
              <span class="shrink-0" style="color: var(--accent-balise);">•</span>
              {item}
            </li>
          ))}
        </ul>
      </section>
    </div>

    <div class="grid md:grid-cols-2 gap-8 mb-10">
      <!-- Points forts -->
      <section>
        <h2 class="text-lg font-semibold mb-4" style="color: var(--secondary-foret);">Points forts</h2>
        <ul class="space-y-2">
          {f.strengths.map(item => (
            <li class="flex gap-2 text-sm" style="color: var(--primary-abime);">
              <span class="shrink-0 font-bold" style="color: var(--secondary-foret);">+</span>
              {item}
            </li>
          ))}
        </ul>
      </section>

      <!-- Points faibles -->
      <section>
        <h2 class="text-lg font-semibold mb-4" style="color: var(--secondary-foret);">Points faibles</h2>
        <ul class="space-y-2">
          {f.weaknesses.map(item => (
            <li class="flex gap-2 text-sm" style="color: var(--primary-abime);">
              <span class="shrink-0 font-bold text-red-500">−</span>
              {item}
            </li>
          ))}
        </ul>
      </section>
    </div>

    <!-- Caracteristiques -->
    <section class="mb-10">
      <h2 class="text-lg font-semibold mb-4" style="color: var(--secondary-foret);">Caracteristiques</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        <div class="bg-white border rounded-lg p-3" style="border-color: var(--neutral-calcaire);">
          <div class="text-xs mb-1" style="color: #64748b;">Meta-framework</div>
          <div class="text-sm font-medium" style="color: var(--primary-abime);">{f.metaFramework}</div>
        </div>
        <div class="bg-white border rounded-lg p-3" style="border-color: var(--neutral-calcaire);">
          <div class="text-xs mb-1" style="color: #64748b;">Courbe apprentissage</div>
          <div class="text-sm">{learningLabel[f.learningCurve]}</div>
        </div>
        <div class="bg-white border rounded-lg p-3" style="border-color: var(--neutral-calcaire);">
          <div class="text-xs mb-1" style="color: #64748b;">Ecosysteme</div>
          <div class="text-sm" style="color: var(--accent-balise);">{ecosystemLabel[f.ecosystem]}</div>
        </div>
        <div class="bg-white border rounded-lg p-3" style="border-color: var(--neutral-calcaire);">
          <div class="text-xs mb-1" style="color: #64748b;">Mobile natif</div>
          <div class="text-sm" style="color: var(--primary-abime);">{f.mobileCrossplatform ? '✅ Oui (React Native)' : '— Non'}</div>
        </div>
      </div>
    </section>

    <!-- AI-First -->
    <section class="mb-10 bg-white border rounded-xl p-6" style="border-left: 4px solid var(--accent-balise); border-color: var(--neutral-calcaire); border-left-color: var(--accent-balise);">
      <h2 class="text-lg font-semibold mb-3" style="color: var(--secondary-foret);">
        🤖 Compatibilite AI-First
        <span class="ml-2" style="color: var(--accent-balise);">{'★'.repeat(f.aiFirst.score)}{'☆'.repeat(5 - f.aiFirst.score)}</span>
      </h2>
      <p class="text-sm" style="color: var(--primary-abime);">{f.aiFirst.notes}</p>
    </section>

    <!-- Navigation -->
    <div class="flex justify-between mt-12 pt-6 border-t" style="border-color: var(--neutral-calcaire);">
      <a href="/compare" class="text-sm transition-colors hover:opacity-70" style="color: #475569;">← Matrice comparative</a>
      <a href="/wizard" class="text-sm transition-colors hover:opacity-70" style="color: var(--accent-balise);">Utiliser le wizard →</a>
    </div>
  </div>
</BaseLayout>
