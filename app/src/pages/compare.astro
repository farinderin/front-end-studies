---
import BaseLayout from '../layouts/BaseLayout.astro';
import { frameworks } from '../data/frameworks';

const criteria = [
  { key: 'bundleStarter', label: 'Bundle starter' },
  { key: 'tti', label: 'TTI (Time to Interactive)' },
  { key: 'rps', label: 'RPS serveur' },
  { key: 'adoption', label: 'Adoption devs' },
  { key: 'satisfaction', label: 'Satisfaction' },
];

const learningLabels = { facile: '🟢 Facile', moderee: '🟡 Moderee', difficile: '🔴 Difficile' };
const ecosystemLabels = { 'tres-grand': '★★★★', grand: '★★★', moyen: '★★', petit: '★' };
---

<BaseLayout title="Matrice comparative" description="Comparatif complet des frameworks frontend 2025-2026">
  <div class="max-w-7xl mx-auto px-4 py-16">
    <h1 class="text-3xl font-bold text-white mb-2">Matrice comparative</h1>
    <p class="text-gray-400 mb-10">Benchmarks et criteres cles pour choisir votre framework. Source : ecosysteme web 2025–2026.</p>

    <!-- Tableau principal -->
    <div class="overflow-x-auto rounded-xl border border-gray-800">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-gray-900 border-b border-gray-800">
            <th class="text-left px-4 py-3 text-gray-400 font-medium w-48">Critere</th>
            {frameworks.map(f => (
              <th class="text-center px-4 py-3 font-medium">
                <a href={`/frameworks/${f.id}`} class="hover:text-indigo-300 transition-colors">
                  <span class="block text-xl mb-1">{f.icon}</span>
                  <span style={`color: ${f.color}`}>{f.name} {f.version}</span>
                </a>
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          <!-- Benchmarks -->
          <tr class="bg-gray-900/30">
            <td colspan={frameworks.length + 1} class="px-4 py-2 text-xs text-indigo-400 font-semibold uppercase tracking-wider">
              Benchmarks de performance
            </td>
          </tr>
          {criteria.map((c, i) => (
            <tr class={`border-t border-gray-800 ${i % 2 === 0 ? '' : 'bg-gray-900/20'}`}>
              <td class="px-4 py-3 text-gray-400">{c.label}</td>
              {frameworks.map(f => (
                <td class="px-4 py-3 text-center font-mono text-white text-xs">
                  {f.benchmarks[c.key as keyof typeof f.benchmarks]}
                </td>
              ))}
            </tr>
          ))}

          <!-- Caracteristiques -->
          <tr class="bg-gray-900/30 border-t border-gray-800">
            <td colspan={frameworks.length + 1} class="px-4 py-2 text-xs text-indigo-400 font-semibold uppercase tracking-wider">
              Caracteristiques
            </td>
          </tr>
          <tr class="border-t border-gray-800">
            <td class="px-4 py-3 text-gray-400">Courbe d'apprentissage</td>
            {frameworks.map(f => (
              <td class="px-4 py-3 text-center text-xs">{learningLabels[f.learningCurve]}</td>
            ))}
          </tr>
          <tr class="border-t border-gray-800 bg-gray-900/20">
            <td class="px-4 py-3 text-gray-400">Ecosysteme</td>
            {frameworks.map(f => (
              <td class="px-4 py-3 text-center text-yellow-400">{ecosystemLabels[f.ecosystem]}</td>
            ))}
          </tr>
          <tr class="border-t border-gray-800">
            <td class="px-4 py-3 text-gray-400">Mobile cross-platform</td>
            {frameworks.map(f => (
              <td class="px-4 py-3 text-center">{f.mobileCrossplatform ? '✅' : '—'}</td>
            ))}
          </tr>
          <tr class="border-t border-gray-800 bg-gray-900/20">
            <td class="px-4 py-3 text-gray-400">Score AI-First</td>
            {frameworks.map(f => (
              <td class="px-4 py-3 text-center text-yellow-400">
                {'★'.repeat(f.aiFirst.score)}{'☆'.repeat(5 - f.aiFirst.score)}
              </td>
            ))}
          </tr>
          <tr class="border-t border-gray-800">
            <td class="px-4 py-3 text-gray-400">Meta-framework</td>
            {frameworks.map(f => (
              <td class="px-4 py-3 text-center text-xs text-gray-300">{f.metaFramework}</td>
            ))}
          </tr>

          <!-- Patterns de rendu -->
          <tr class="bg-gray-900/30 border-t border-gray-800">
            <td colspan={frameworks.length + 1} class="px-4 py-2 text-xs text-indigo-400 font-semibold uppercase tracking-wider">
              Patterns de rendu
            </td>
          </tr>
          {(['SSG', 'SSR', 'SPA', 'Islands', 'Edge', 'PWA', 'ISR', 'PPR'] as const).map((pattern, i) => (
            <tr class={`border-t border-gray-800 ${i % 2 === 0 ? '' : 'bg-gray-900/20'}`}>
              <td class="px-4 py-3 text-gray-400 font-mono text-xs">{pattern}</td>
              {frameworks.map(f => (
                <td class="px-4 py-3 text-center">
                  {f.renderPatterns.includes(pattern) ? '✅' : '—'}
                </td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Matrice de decision -->
    <div class="mt-16">
      <h2 class="text-2xl font-bold text-white mb-6">Matrice de decision</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          { criteria: 'Enterprise Scale', winner: 'Angular', why: 'Structure predictible et stabilite long terme', color: '#DD0031' },
          { criteria: 'Hiring Velocity', winner: 'React', why: 'Plus grand vivier de talents (91% adoption)', color: '#61DAFB' },
          { criteria: 'Raw Performance', winner: 'Svelte', why: 'Bundles les plus petits, 1200 RPS, TTI 200ms', color: '#FF3E00' },
          { criteria: 'Content / SEO', winner: 'Astro', why: 'Zero JS, meilleur LCP, Islands Architecture', color: '#FF5D01' },
          { criteria: 'Rapid Onboarding', winner: 'Vue', why: 'Syntaxe template intuitive, courbe douce', color: '#42B883' },
          { criteria: 'AI-First Development', winner: 'React / Next.js', why: '4x donnees entrainement, Vercel AI SDK', color: '#61DAFB' },
        ].map(row => (
          <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
            <div class="text-xs text-gray-500 uppercase tracking-wider mb-2">{row.criteria}</div>
            <div class="text-lg font-bold mb-1" style={`color: ${row.color}`}>{row.winner}</div>
            <div class="text-sm text-gray-400">{row.why}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
